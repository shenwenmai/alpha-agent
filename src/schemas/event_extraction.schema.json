{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["financial_loss", "collapse", "emotion", "evidence"] },
    "status": { "type": "string", "enum": ["confirmed", "needs_review", "dropped"] },
    "data": { "type": "object" },
    "meta": {
      "type": "object",
      "properties": {
        "sourceMessageId": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "model_version": { "type": "string" }
      },
      "required": ["sourceMessageId", "confidence"]
    }
  },
  "required": ["id", "type", "status", "meta"]
}
